<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shortly — URL Shortener</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style> body { font-family: 'Inter', sans-serif; } </style>
</head>
<body class="bg-slate-50 min-h-screen">

    <%- include('partials/navbar') %>

    <!-- Hero Section -->
    <div class="max-w-4xl mx-auto px-6 pt-16 pb-10 text-center">
        <h1 class="text-4xl font-bold text-slate-900 mb-3">
            Shorten any link, instantly
        </h1>
        <p class="text-slate-500 text-lg mb-10">
            Paste a long URL and get a clean, shareable short link in seconds.
        </p>

        <!-- Shorten Form -->
        <form method="POST" action="/api/shorten" 
              class="flex gap-3 max-w-2xl mx-auto">
            <input 
                type="text" 
                name="url"
                placeholder="https://example.com/very/long/url" 
                class="flex-1 px-4 py-3 rounded-lg border border-slate-200 bg-white text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent shadow-sm text-sm"
            >
            <button type="submit" 
                    class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-medium text-sm transition-colors shadow-sm whitespace-nowrap">
                Shorten URL
            </button>
        </form>

        <!-- Generated Short URL (signature element) -->
        <% if (locals.id) { %>
        <div class="mt-6 inline-flex items-center gap-3 bg-blue-50 border border-blue-100 rounded-lg px-5 py-3">
            <span class="text-slate-500 text-sm">Your short link:</span>
            <a href="<%= baseUrl %><%= id %>" 
               target="_blank"
               class="font-mono text-blue-600 font-semibold text-sm hover:text-blue-700 transition-colors">
                localhost:3000/<%= id %>
            </a>
        </div>
        <% } %>
    </div>

    <!-- URLs Table -->
    <div class="max-w-4xl mx-auto px-6 pb-16">
        <% if (locals.urls && urls.length > 0) { %>
        <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-100">
                <h2 class="text-sm font-semibold text-slate-700">Recent Links</h2>
            </div>
            <table class="w-full">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="text-left text-xs font-medium text-slate-500 uppercase tracking-wide px-6 py-3">#</th>
                        <th class="text-left text-xs font-medium text-slate-500 uppercase tracking-wide px-6 py-3">Short ID</th>
                        <th class="text-left text-xs font-medium text-slate-500 uppercase tracking-wide px-6 py-3">Original URL</th>
                        <th class="text-left text-xs font-medium text-slate-500 uppercase tracking-wide px-6 py-3">Clicks</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    <% urls.forEach((url, index) => { %>
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="px-6 py-4 text-sm text-slate-400"><%= index + 1 %></td>
                        <td class="px-6 py-4">
                            <a href="/<%= url.shortId %>" target="_blank"
                               class="font-mono text-blue-600 text-sm hover:text-blue-700 font-medium">
                                <%= url.shortId %>
                            </a>
                        </td>
                        <td class="px-6 py-4 text-sm text-slate-600 max-w-xs truncate">
                            <a href="<%= url.redirectURL %>" target="_blank" 
                               class="hover:text-blue-600 transition-colors">
                                <%= url.redirectURL %>
                            </a>
                        </td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-700">
                                <%= url.visitHistory.length %> clicks
                            </span>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        <% } %>
    </div>

</body>
</html>