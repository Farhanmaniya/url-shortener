<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Links — Shortly</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style> body { font-family: 'Inter', sans-serif; } </style>
</head>
<body class="bg-slate-50 min-h-screen">

    <%- include('partials/navbar') %>

    <div class="max-w-4xl mx-auto px-6 py-12">

        <div class="mb-8">
            <h1 class="text-2xl font-bold text-slate-900">My Links</h1>
            <p class="text-slate-500 text-sm mt-1">All the links you've shortened</p>
        </div>

        <% if (urls.length === 0) { %>
        <div class="bg-white border border-slate-200 rounded-xl shadow-sm p-12 text-center">
            <p class="text-slate-500 text-sm">You haven't shortened any links yet.</p>
            <a href="/" class="inline-block mt-4 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-5 py-2.5 rounded-lg transition-colors">
                Shorten your first link
            </a>
        </div>

        <% } else { %>
        <div class="bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden">
            <table class="w-full">
                <thead class="bg-slate-50 border-b border-slate-200">
                    <tr>
                        <th class="text-left text-xs font-medium text-slate-500 uppercase tracking-wide px-6 py-3">#</th>
                        <th class="text-left text-xs font-medium text-slate-500 uppercase tracking-wide px-6 py-3">Short Link</th>
                        <th class="text-left text-xs font-medium text-slate-500 uppercase tracking-wide px-6 py-3">Original URL</th>
                        <th class="text-left text-xs font-medium text-slate-500 uppercase tracking-wide px-6 py-3">Clicks</th>
                        <th class="text-left text-xs font-medium text-slate-500 uppercase tracking-wide px-6 py-3">Created</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    <% urls.forEach((url, index) => { %>
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="px-6 py-4 text-sm text-slate-400"><%= index + 1 %></td>
                        <td class="px-6 py-4">
                            <a href="/<%= url.shortId %>" target="_blank"
                               class="font-mono text-blue-600 text-sm hover:text-blue-700 font-medium">
                                shortly/<%= url.shortId %>
                            </a>
                        </td>
                        <td class="px-6 py-4 text-sm text-slate-600 max-w-xs truncate">
                            <a href="<%= url.redirectURL %>" target="_blank"
                               class="hover:text-blue-600 transition-colors">
                                <%= url.redirectURL %>
                            </a>
                        </td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-700">
                                <%= url.visitHistory.length %> clicks
                            </span>
                        </td>
                        <td class="px-6 py-4 text-sm text-slate-400">
                            <%= new Date(url.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        <% } %>

    </div>

</body>
</html>